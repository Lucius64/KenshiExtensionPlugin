msgstr "武術クラス"

#: KenshiExtensionPlugin/src/ItemExtension.cpp:68
msgid "Turret class"
msgstr "砲台クラス"

#: KenshiExtensionPlugin/src/ItemExtension.cpp:120
#: kep-mod-tool/DevToolsPanel.cpp:196
msgid "Harpoon damage"
msgstr "ハープーンダメージ"

#: KenshiExtensionPlugin/src/ItemExtension.cpp:150
#, c++-format
msgid "Damage vs {1} race"
msgstr "対{1}種族ダメージ"

#: KenshiExtensionPlugin/src/ItemExtension.cpp:178
